<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.Region?>

<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="700.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MenuPrincipalController">

    <children>

        <VBox fx:id="sideMenu" alignment="TOP_CENTER" prefWidth="180.0"
              style="-fx-background-color: #EEEEEE;"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>

                <ImageView fx:id="imgLogoMenu" fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/components/logo.png"/>
                    </image>
                    <VBox.margin>
                        <Insets bottom="30.0" top="20.0"/>
                    </VBox.margin>
                </ImageView>

                <Button fx:id="btnDashboard" text=" Dashboard" prefWidth="150.0" alignment="BASELINE_LEFT"
                        styleClass="menu-button" onAction="#handleDashboard">
                    <font><Font size="13.0"/></font>
                    <VBox.margin><Insets bottom="15.0"/></VBox.margin>
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0"><Image url="@/components/Activity.png"/></ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnCadastroVendas" text=" Vendas" prefWidth="150.0" alignment="BASELINE_LEFT"
                        styleClass="menu-button" onAction="#handleCadastroVendas">
                    <font><Font size="13.0"/></font>
                    <VBox.margin><Insets bottom="15.0"/></VBox.margin>
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0"><Image url="@/components/Bag 3.png"/></ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnAgendamento" text=" Agendamento" prefWidth="150.0" alignment="BASELINE_LEFT"
                        styleClass="menu-button" onAction="#handleAgendamento">
                    <font><Font size="13.0"/></font>
                    <VBox.margin><Insets bottom="15.0"/></VBox.margin>
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0"><Image url="@/components/Calendar.png"/></ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnEstoque" text=" Estoque" prefWidth="150.0" alignment="BASELINE_LEFT"
                        styleClass="menu-button" onAction="#handleEstoque">
                    <font><Font size="13.0"/></font>
                    <VBox.margin><Insets bottom="15.0"/></VBox.margin>
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0"><Image url="@/components/Graph.png"/></ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnRelatorios" text=" Relatórios" prefWidth="150.0" alignment="BASELINE_LEFT"
                        styleClass="menu-button" onAction="#handleRelatorios">
                    <font><Font size="13.0"/></font>
                    <VBox.margin><Insets bottom="15.0"/></VBox.margin>
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0"><Image url="@/components/Chart.png"/></ImageView>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnSair" text=" Sair" prefWidth="150.0" alignment="BASELINE_LEFT"
                        styleClass="menu-exit-button" onAction="#handleSair">
                    <font><Font name="System Bold" size="14.0" /></font>
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0"><Image url="@/components/Logout.png"/></ImageView>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="50.0"/>
                    </VBox.margin>
                </Button>

            </children>
        </VBox>

        <AnchorPane fx:id="mainContentPane"
                    style="-fx-background-color: #F5F5F5;"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="180.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0" />

    </children>
</AnchorPane>