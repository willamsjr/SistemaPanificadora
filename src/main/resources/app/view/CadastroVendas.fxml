<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.Region?>
<AnchorPane prefHeight="620.0" prefWidth="1010.0"
            style="-fx-background-color: #EEEEEE;"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CadastroVendasController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>

        <VBox spacing="20" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <!-- TÍTULO -->
            <Label text="Cadastro de Vendas">
                <font><Font name="System Bold" size="24"/></font>
            </Label>

            <!-- BOTÕES: FUNCIONÁRIOS + USUÁRIOS -->
            <HBox spacing="10">

                <Button fx:id="btnGerenciarFuncionarios"
                        text="👤 Cadastrar Funcionários"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"
                        prefWidth="200" prefHeight="35"/>

                <Button fx:id="btnGerenciarUsuarios"
                        text="👤 Gerenciar Usuários"
                        style="-fx-background-color: #9b59b6; -fx-text-fill: white;"
                        prefWidth="200" prefHeight="35"/>

            </HBox>

            <!--  VENDAS + TABELA -->

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 20;">
                <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
                <effect>
                    <javafx.scene.effect.DropShadow blurType="GAUSSIAN" height="30.0" radius="14.5" width="30.0">
                        <color><javafx.scene.paint.Color opacity="0.1" /></color>
                    </javafx.scene.effect.DropShadow>
                </effect>
                <children>
                    <Label text="🛒 Novo Item" style="-fx-font-weight: bold;">
                        <font><Font size="18.0" /></font>
                    </Label>

                    <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                        <children>
                            <VBox HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="ID ou Nome do Produto" />
                                    <TextField fx:id="txtProdutoBusca" prefHeight="40.0" promptText="Buscar produto..." style="-fx-background-color: #F0F0F0; -fx-background-radius: 10;" />
                                </children>
                            </VBox>
                            <VBox>
                                <children>
                                    <Label text="Qtd." />
                                    <TextField fx:id="txtProdutoQtd" alignment="CENTER" prefHeight="40.0" prefWidth="70.0" text="1" style="-fx-background-color: #F0F0F0; -fx-background-radius: 10;" />
                                </children>
                            </VBox>
                            <Button fx:id="btnAdicionarItem" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #FFD700; -fx-background-radius: 10; -fx-font-weight: bold;" text="ADICIONAR" />
                        </children>
                    </HBox>
                </children>
            </VBox>
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20;" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                <effect>
                    <javafx.scene.effect.DropShadow blurType="GAUSSIAN" radius="14.5"><color><javafx.scene.paint.Color opacity="0.1" /></color></javafx.scene.effect.DropShadow>
                </effect>
                <children>
                    <TableView fx:id="tblItensVenda" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-selection-bar: #FFD700; -fx-selection-bar-non-focused: #FFFACD; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #E0E0E0;">

                        <columns>
                            <TableColumn fx:id="colProdutoNome" prefWidth="350" text="📦 PRODUTO"
                                         style="-fx-alignment: CENTER-LEFT; -fx-font-weight: bold;" />

                            <TableColumn fx:id="colProdutoQtd" prefWidth="100" text="QUANTIDADE"
                                         style="-fx-alignment: CENTER;" />

                            <TableColumn fx:id="colProdutoPrecoUnit" prefWidth="150" text="PREÇO UNITÁRIO"
                                         style="-fx-alignment: CENTER-RIGHT;" />

                            <TableColumn fx:id="colProdutoPrecoTotal" prefWidth="150" text="TOTAL"
                                         style="-fx-alignment: CENTER-RIGHT; -fx-text-fill: #27ae60; -fx-font-weight: bold;" />
                        </columns>

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <HBox spacing="20" alignment="CENTER_RIGHT">

                        <Button fx:id="btnRemoverItem"
                                text="REMOVER ITEM"
                                prefWidth="180" prefHeight="45"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 15; -fx-font-weight: bold;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Label fx:id="lblTotalVenda" text="TOTAL: R$ 0,00">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>

                        <Button fx:id="btnFinalizarVenda"
                                text="FINALIZAR VENDA"
                                prefWidth="220" prefHeight="45"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 15; -fx-font-weight: bold;">
                            <font><Font size="16"/></font>
                        </Button>
                    </HBox>
                </children>
            </VBox>

        </VBox>

    </children>

</AnchorPane>
