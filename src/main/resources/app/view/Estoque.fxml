<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.*?>

<AnchorPane prefHeight="700" prefWidth="1100" style="-fx-background-color: #EEEEEE;" stylesheets="@/app/css/styles.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.EstoqueController">

    <children>
        <VBox spacing="15" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">
                <children>
                    <Label text="Estoque">
                        <font>
                            <Font name="System Bold" size="24" />
                        </font>
                    </Label>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnAjuda" prefHeight="40.0" prefWidth="40.0"
                            style="-fx-background-radius: 50; -fx-background-color: #ffd000; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 18;"
                            text="?" />
                </children>
            </HBox>

            <HBox spacing="35" VBox.vgrow="ALWAYS">
                <children>

                    <VBox spacing="15" HBox.hgrow="ALWAYS">
                        <children>
                            <TableView fx:id="tableEstoque" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                                    <TableColumn fx:id="colNome" prefWidth="280" text="PRODUTO" />
                                    <TableColumn fx:id="colPreco" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;" text="PREÇO (R$)" />
                                    <TableColumn fx:id="colQtd" prefWidth="100" style="-fx-alignment: CENTER;" text="QUANTIDADE" />
                                    <TableColumn fx:id="colMin" prefWidth="100" style="-fx-alignment: CENTER;" text="QUANTIDADE MIN." />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>

                            <HBox alignment="CENTER" spacing="15">
                                <children>
                                    <Button fx:id="btnEditarProduto" prefHeight="40" prefWidth="180" style="-fx-background-color: #ffd000; -fx-font-weight: bold; -fx-cursor: hand;" text="EDITAR PRODUTO" />
                                    <Button fx:id="btnExcluirProduto" prefHeight="40" prefWidth="180" style="-fx-background-color: #e74c3c; -fx-font-weight: bold; -fx-cursor: hand;" text="EXCLUIR PRODUTO" />
                                    <Button fx:id="btnAtualizar" prefHeight="40" prefWidth="180" style="-fx-background-color: #3299CC; -fx-font-weight: bold; -fx-cursor: hand;" text="ATUALIZAR" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox prefWidth="300" spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <children>
                            <Label text="Cadastrar Produto">
                                <font><Font name="System Bold" size="16.0" /></font>
                            </Label>
                            <Region prefHeight="10" />
                            <Label style="-fx-font-weight: bold;" text="Nome do Produto" />
                            <TextField fx:id="txtNome" prefHeight="35" promptText="Ex: Pão Francês" />
                            <Label style="-fx-font-weight: bold;" text="Preço (R$)" />
                            <TextField fx:id="txtPreco" prefHeight="35" promptText="Ex: 0.75" />
                            <Label style="-fx-font-weight: bold;" text="Quantidade" />
                            <TextField fx:id="txtQuantidade" prefHeight="35" promptText="Ex: 300" />
                            <Label style="-fx-font-weight: bold;" text="Quantidade Mínima" />
                            <TextField fx:id="txtMinima" prefHeight="35" promptText="Ex: 10" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Button fx:id="btnCadastrarProduto" maxWidth="Infinity" prefHeight="45" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="CADASTRAR PRODUTO" />
                        </children>
                    </VBox>

                </children>
            </HBox>
        </VBox>
    </children>
</AnchorPane>