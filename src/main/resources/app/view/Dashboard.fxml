<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.Region?>
<AnchorPane prefHeight="590.0" prefWidth="760.0" style="-fx-background-color: #EEEEEE;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardContentController">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Dashboard - Visão Geral">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <VBox layoutX="30.0" layoutY="80.0" spacing="20.0">
            <children>
                <Label text="Estatísticas Rápidas de Hoje">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 5;">
                            <children>
                                <Label text="VENDAS HOJE" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="5.0" />
                                    </VBox.margin>
                                </Label>
                                <Label fx:id="lblTotalVendasHoje" text="R$ 0.00" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #f1c40f; -fx-background-radius: 5;">
                            <children>
                                <Label text="AGENDAMENTOS PENDENTES" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="5.0" />
                                    </VBox.margin>
                                </Label>
                                <Label fx:id="lblAgendamentosPendentes" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #e74c3c; -fx-background-radius: 5;">
                            <children>
                                <Label text="ESTOQUE BAIXO" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="5.0" />
                                    </VBox.margin>
                                </Label>
                                <Label fx:id="lblEstoqueBaixo" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                    </children>
                </HBox>
                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <VBox prefWidth="400.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #CCCCCC; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>
                        <children>
                            <Label text="Últimas Vendas">
                                <font>
                                    <Font name="System Bold" size="18.0" />
                                </font>
                                <VBox.margin>
                                    <Insets bottom="15.0" />
                                </VBox.margin>
                            </Label>

                            <VBox fx:id="vboxUltimasVendas" spacing="10.0" VBox.vgrow="ALWAYS">
                                <children>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
