<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.*?>

<AnchorPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.RelatoriosController"
            prefWidth="1010.0" prefHeight="700.0"
            style="-fx-background-color: #EEEEEE;">

    <children>
        <VBox spacing="20" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

            <HBox spacing="20" style="-fx-background-color: #EEEEEE;" prefHeight="70" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="0" right="20" bottom="0" left="20"/>
                </padding>
                <Label text="Relatório de Vendas" textFill="black">
                    <font>
                        <Font name="System Bold" size="24" />
                    </font>
                </Label>
            </HBox>

            <VBox spacing="20" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="20" bottom="20" left="20"/>
                </padding>

                <HBox spacing="20" prefHeight="180">
                    <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="VENDAS NO PERÍODO" textFill="#666666">
                            <font><Font size="12" name="System Bold"/></font>
                        </Label>
                        <Label fx:id="lblTotalVendasPeriodo" text="0" textFill="#6e0d0d" wrapText="true">
                            <font><Font size="22" name="System Bold"/></font>
                        </Label>
                    </VBox>

                    <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="VALOR TOTAL (R$)" textFill="#666666">
                            <font><Font size="12" name="System Bold"/></font>
                        </Label>
                        <Label fx:id="lblValorTotalPeriodo" text="R$ 0,00" textFill="#27ae60" wrapText="true">
                            <font><Font size="22" name="System Bold"/></font>
                        </Label>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" prefWidth="450"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <BarChart fx:id="barChartVendas" legendVisible="false" prefHeight="120">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </BarChart>
                    </VBox>
                </HBox>

                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Início"/><DatePicker fx:id="datePickerInicio" prefWidth="110"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Fim"/><DatePicker fx:id="datePickerFim" prefWidth="110"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Funcionário"/><ComboBox fx:id="comboFuncionario" prefWidth="140" promptText="Todos"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Produto/Busca"/><TextField fx:id="txtBuscaRapida" promptText="Nome ou ID" prefWidth="130"/>
                        </VBox>

                        <TextField fx:id="txtProdutoFiltro" visible="false" managed="false" />
                        <TextField fx:id="txtMinValor" visible="false" managed="false" />
                        <TextField fx:id="txtMaxValor" visible="false" managed="false" />

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="10" alignment="BOTTOM_RIGHT">
                            <Button fx:id="btnLimpar" onAction="#handleLimpar" text="Limpar"
                                    style="-fx-background-color: #E0E0E0; -fx-cursor: hand;"
                                    prefHeight="32" prefWidth="80"/>
                            <Button fx:id="btnBuscar" onAction="#handleBuscarPeriodoComFiltros" text="Filtrar"
                                    style="-fx-background-color: #ffd000; -fx-text-fill: #333; -fx-font-weight: bold; -fx-cursor: hand;"
                                    prefHeight="32" prefWidth="100"/>
                        </HBox>
                    </HBox>
                </VBox>

                <TableView fx:id="tblVendas" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="colIdVenda" text="ID" prefWidth="50" />
                        <TableColumn fx:id="colData" text="DATA/HORA" prefWidth="140" />
                        <TableColumn fx:id="colFuncionario" text="FUNCIONÁRIO" prefWidth="150"/>
                        <TableColumn fx:id="colProduto" text="PRODUTO" prefWidth="200"/>
                        <TableColumn fx:id="colQuantidade" text="QTD." prefWidth="60"/>
                        <TableColumn fx:id="colValorTotal" text="TOTAL" prefWidth="100"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <Button onAction="#handleExportarPDF" text="Exportar PDF"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                        prefHeight="32" prefWidth="110"/>
            </VBox>
        </VBox>
    </children>
</AnchorPane>