<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.*?>

<AnchorPane prefHeight="700.0" prefWidth="1010.0" style="-fx-background-color: #EEEEEE;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RelatoriosController">
    <children>
        <VBox spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="20" style="-fx-background-color: #EEEEEE;">
                    <padding>
                        <Insets bottom="0" left="20" right="20" top="0" />
                    </padding>

                    <children>
                        <Label text="Relatório de Vendas" textFill="black">
                            <font>
                                <Font name="System Bold" size="24" />
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnAjuda"
                                text="?"
                                onAction="#acaoBotaoAjuda"
                                prefWidth="45.0" prefHeight="45.0"
                                minWidth="45.0" minHeight="45.0"
                                style="-fx-background-color: #f1c40f; -fx-text-fill: black; -fx-background-radius: 50; -fx-font-weight: bold; -fx-font-size: 18; -fx-cursor: hand;" />
                    </children>
                </HBox>

                <VBox spacing="20" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="10" />
                    </padding>
                    <children>

                        <HBox prefHeight="180" spacing="20">
                            <children>
                                <VBox maxWidth="Infinity" spacing="8" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="VENDAS NO PERÍODO" textFill="#666666">
                                            <font><Font name="System Bold" size="12" /></font>
                                        </Label>
                                        <Label fx:id="lblTotalVendasPeriodo" text="0" textFill="#6e0d0d" wrapText="true">
                                            <font><Font name="System Bold" size="22" /></font>
                                        </Label>
                                    </children>
                                </VBox>

                                <VBox maxWidth="Infinity" spacing="8" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="VALOR TOTAL (R$)" textFill="#666666">
                                            <font><Font name="System Bold" size="12" /></font>
                                        </Label>
                                        <Label fx:id="lblValorTotalPeriodo" text="R$ 0,00" textFill="#27ae60" wrapText="true">
                                            <font><Font name="System Bold" size="22" /></font>
                                        </Label>
                                    </children>
                                </VBox>

                                <VBox prefWidth="450" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                                    <children>
                                        <BarChart fx:id="barChartVendas" legendVisible="false" prefHeight="120">
                                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                                        </BarChart>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <children>
                                        <VBox spacing="4">
                                            <children><Label text="Início" /><DatePicker fx:id="datePickerInicio" prefWidth="110" /></children>
                                        </VBox>
                                        <VBox spacing="4">
                                            <children><Label text="Fim" /><DatePicker fx:id="datePickerFim" prefWidth="110" /></children>
                                        </VBox>
                                        <VBox spacing="4">
                                            <children><Label text="Funcionário" /><ComboBox fx:id="comboFuncionario" prefWidth="140" promptText="Todos" /></children>
                                        </VBox>
                                        <VBox spacing="4">
                                            <children><Label text="Produto/Busca" /><TextField fx:id="txtBuscaRapida" prefWidth="130" promptText="Nome ou ID" /></children>
                                        </VBox>

                                        <Region HBox.hgrow="ALWAYS" />

                                        <HBox alignment="BOTTOM_RIGHT" spacing="10">
                                            <children>
                                                <Button fx:id="btnLimpar" onAction="#handleLimpar" prefHeight="32" prefWidth="80" style="-fx-background-color: #E0E0E0; -fx-cursor: hand;" text="Limpar" />
                                                <Button fx:id="btnBuscar" onAction="#handleBuscarPeriodoComFiltros" prefHeight="32" prefWidth="100" style="-fx-background-color: #ffd000; -fx-text-fill: #333; -fx-font-weight: bold; -fx-cursor: hand;" text="Filtrar" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <TableView fx:id="tblVendas" style="-fx-background-color: white;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colIdVenda" prefWidth="50" text="ID" />
                                <TableColumn fx:id="colData" prefWidth="140" text="DATA/HORA" />
                                <TableColumn fx:id="colFuncionario" prefWidth="150" text="FUNCIONÁRIO" />
                                <TableColumn fx:id="colProduto" prefWidth="200" text="PRODUTO" />
                                <TableColumn fx:id="colQuantidade" prefWidth="60" text="QTD." />
                                <TableColumn fx:id="colValorTotal" prefWidth="100" text="TOTAL" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <Button onAction="#handleExportarPDF" prefHeight="32" prefWidth="110" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Exportar PDF" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>